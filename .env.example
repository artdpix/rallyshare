# Postgres
DATABASE_URL=postgresql://rally:rally@localhost:5432/rally

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Storage (filesystem for now). Relative paths resolve against repo root.
MEDIA_ROOT=./media
MAX_UPLOAD_BYTES=262144000

# IP hashing salt (HMAC). Change to a long random string in production.
IP_HASH_SALT=dev-salt-change-me

# Token de acesso ao /admin (régie). Partilhar só com operadores.
# Gerar com:  openssl rand -hex 24
# Será substituído por Cloudflare Access JWT no Sprint 2.
ADMIN_TOKEN=

# Cloudflare Turnstile (placeholder — get keys from CF dashboard)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# vMix (placeholder — set when vMix is reachable via WG)
VMIX_API_URL=http://10.8.0.20:8088/api
VMIX_LOCAL_MEDIA_PATH=C:\rally\sync
